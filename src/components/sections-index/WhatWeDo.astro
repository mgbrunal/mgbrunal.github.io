---
import Store from "../../assets/icons/Store.astro";
import Rocket2 from "../../assets/icons/Rocket2.astro";
import Design from "../../assets/icons/Design.astro";
import Develop from "../../assets/icons/Develop.astro";
import Validation from "../../assets/icons/Validation.astro";

const items = [
  {
    title: "Páginas web para negocios",
    content: "Sitios diseñados para comunicar con claridad, generar confianza y facilitar el contacto con clientes potenciales.",
    icon: "store",
  },
  {
    title: "Páginas web para eventos",
    content: "Espacios digitales para informar, registrar asistentes y centralizar toda la comunicación del evento.",
    icon: "rocket",
  },
  {
    title: "Proyectos inmobiliarios",
    content: "Páginas enfocadas en captar interés real y organizar la información de posibles compradores.",
    icon: "design",
  },
  {
    title: "Automatización de procesos",
    content: "Flujos que conectan formularios, mensajes y herramientas para reducir tareas manuales y mejorar el seguimiento.",
    icon: "develop",
  },
  {
    title: "Desarrollos a medida",
    content: "Soluciones personalizadas según necesidades específicas que no encajan en un formato estándar.",
    icon: "custom",
  },
  {
    title: "Optimización y soporte",
    content: "Ajustes, mejoras y mantenimiento para que todo siga funcionando correctamente en el tiempo.",
    icon: "support",
  },
];

const numColor = ["text-tertiary", "text-secondary"];
const titleHover = ["can-hover:group-hover:text-tertiary", "can-hover:group-hover:text-secondary"];
---

<div class="w-full h-full flex flex-col items-center justify-center py-20">
  <div class="w-full h-full xl:max-w-[75%] px-10 sm:px-20">
    <div class="w-full h-full flex flex-col lg:flex-row items-start justify-center gap-8 lg:gap-16">

      <!-- Sticky sidebar -->
      <div class="w-full lg:w-[38%] shrink-0 flex flex-col items-start gap-6 lg:sticky lg:top-20">
        <p data-reveal class="text-sm sm:text-base font-light text-white uppercase">
          Qué hacemos?
        </p>
        <h2 data-reveal data-reveal-delay="80" class="text-3xl sm:text-5xl font-bold text-tertiary drop-shadow-lg">
          Soluciones digitales según la necesidad de tu negocio
        </h2>
        <p data-reveal data-reveal-delay="160" class="text-sm sm:text-lg font-semibold text-white">
          Cada proyecto es distinto. Estas son las principales formas en las
          que podemos ayudarte.
        </p>
      </div>

      <!-- Numbered list -->
      <div class="w-full flex flex-col border-t border-white/10">
        {
          items.map((item, i) => (
            <div data-reveal data-reveal-delay={String(i * 50)} class="group flex flex-row items-start gap-5 py-7 border-b border-white/10 transition-colors duration-200 ease-out can-hover:hover:bg-white/5 px-3 -mx-3">

              <span
                class={`text-4xl sm:text-5xl font-bold tabular-nums leading-none shrink-0 mt-0.5 transition-opacity duration-200 ${numColor[i % 2]}`}
              >
                {String(i + 1).padStart(2, "0")}
              </span>

              <div class="flex flex-col gap-1.5 grow">
                <h3
                  class={`text-sm sm:text-base font-bold uppercase tracking-wide text-white transition-colors duration-200 ease-out ${titleHover[i % 2]}`}
                >
                  {item.title}
                </h3>
                <p class="text-sm font-light text-white/60 leading-relaxed">
                  {item.content}
                </p>
              </div>

              <div class="w-6 h-6 opacity-20 shrink-0 mt-0.5 transition-opacity duration-200 can-hover:group-hover:opacity-40">
                {item.icon === "store" && <Store color="#FFF" />}
                {item.icon === "rocket" && <Rocket2 color="#FFF" />}
                {item.icon === "design" && <Design color="#FFF" />}
                {item.icon === "develop" && <Develop color="#FFF" />}
                {item.icon === "custom" && <Develop color="#FFF" />}
                {item.icon === "support" && <Validation color="#FFF" />}
              </div>

            </div>
          ))
        }
      </div>

    </div>
  </div>
</div>
