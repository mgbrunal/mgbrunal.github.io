---
import ArrowUpRight from "../../assets/icons/ArrowUpRight.astro";
import Store from "../../assets/icons/Store.astro";
import Rocket2 from "../../assets/icons/Rocket2.astro";
import Design from "../../assets/icons/Design.astro";
import Develop from "../../assets/icons/Develop.astro";
import Validation from "../../assets/icons/Validation.astro";

const items = [
  {
    title: "Páginas web para negocios",
    content: "Sitios diseñados para comunicar con claridad, generar confianza y facilitar el contacto con clientes potenciales.",
    icon: "store"
  },
  {
    title: "Páginas web para eventos",
    content: "Espacios digitales para informar, registrar asistentes y centralizar toda la comunicación del evento.",
    icon: "rocket"
  },
  {
    title: "Proyectos inmobiliarios",
    content: "Páginas enfocadas en captar interés real y organizar la información de posibles compradores.",
    icon: "design"
  },
  {
    title: "Automatización de procesos",
    content: "Flujos que conectan formularios, mensajes y herramientas para reducir tareas manuales y mejorar el seguimiento.",
    icon: "develop"
  },
  {
    title: "Desarrollos a medida",
    content: "Soluciones personalizadas según necesidades específicas que no encajan en un formato estándar.",
    icon: "custom"
  },
  {
    title: "Optimización y soporte",
    content: "Ajustes, mejoras y mantenimiento para que todo siga funcionando correctamente en el tiempo.",
    icon: "support"
  },
];


---

<div class="w-full h-full flex flex-col items-center justify-center py-20">
  <div class="w-full h-full xl:max-w-[75%] px-10 sm:px-20">
    <div
      class="w-full h-full flex flex-col lg:flex-row items-start justify-center gap-8"
    >
      <div
        class="w-full h-full flex flex-col items-start justify-center gap-8 lg:sticky lg:top-20"
      >
        <p
          class="text-sm sm:text-base font-light text-white uppercase"
        >
          Qué hacemos?
        </p>

        <h1 class="text-3xl sm:text-5xl font-bold text-tertiary drop-shadow-lg">
          Soluciones digitales según la necesidad de tu negocio
        </h1>

        <p class="text-sm sm:text-lg font-semibold text-white">
          Cada proyecto es distinto. Estas son las principales formas en las que podemos ayudarte.
        </p>
      </div>

      <div class="flex flex-col space-y-4 sm:space-y-8 w-full h-full">
        {
          items.map((item) => (
            <div 
              class="flex flex-col h-auto sm:min-h-[300px] items-start justify-center gap-4 bg-white/70 border-tertiary rounded-xl shadow-xl shadow-black/20 border-2 transition-transform duration-300 ease-out-strong can-hover:hover:scale-[1.02] active:scale-[0.99] p-6 sm:p-8"
            >
              <div 
                class="w-16 h-16 sm:w-20 sm:h-20 flex items-center justify-center rounded-2xl mb-2 bg-primary/50"
              >
                <div class="w-10 h-10 sm:w-12 sm:h-12">
                  {item.icon === "store" && <Store color="#000" />}
                  {item.icon === "rocket" && <Rocket2 color="#000" />}
                  {item.icon === "design" && <Design color="#000" />}
                  {item.icon === "develop" && <Develop color="#000" />}
                  {item.icon === "custom" && <Develop color="#000" />}
                  {item.icon === "support" && <Validation color="#000" />}
                </div>
              </div>
              <h3 
                class="text-xl sm:text-2xl font-bold uppercase tracking-tight text-black"
              >
                {item.title}
              </h3>
              <p class="text-base sm:text-lg font-medium text-black/80 leading-relaxed">
                {item.content}
              </p>
            </div>
          ))
        }
      </div>

    </div>
  </div>
</div>
