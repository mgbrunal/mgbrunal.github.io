---
import WhatWeDoMockups from "./WhatWeDoMockups.astro";
import WhatWeDoList from "./WhatWeDoList.astro";
---

<div class="w-full h-full flex flex-col items-center justify-center py-20" id="whatwedo-root">
  <div class="w-full h-full xl:max-w-[75%] px-5 sm:px-20">
    <div class="w-full h-full flex flex-col lg:flex-row items-start justify-center gap-8 lg:gap-16">

      <!-- Sidebar: always shows text -->
      <div class="w-full lg:w-[38%] shrink-0 lg:sticky lg:top-24">
        <div class="flex flex-col items-start gap-6">
          <p data-reveal class="text-sm sm:text-base font-light text-white uppercase">Qué hacemos?</p>
          <h2 data-reveal data-reveal-delay="80" class="text-3xl sm:text-5xl font-bold text-tertiary drop-shadow-lg">
            Soluciones digitales según la necesidad de tu negocio
          </h2>
          <p data-reveal data-reveal-delay="160" class="text-sm sm:text-lg font-semibold text-white">
            Cada proyecto es distinto. Estas son las principales formas en las que podemos ayudarte.
          </p>
          <p class="hidden lg:block text-xs text-white/30 mt-2">Desplázate o pasa el cursor para explorar</p>
        </div>
      </div>

      <WhatWeDoList />

    </div>
  </div>

  <!-- Hidden clone pool — mockup HTML stays in DOM for JS to clone from -->
  <WhatWeDoMockups />
</div>


<script>
  function initWhatWeDo() {
    const root = document.getElementById("whatwedo-root") as HTMLElement;
    if (!root) return;

    const rows = root.querySelectorAll<HTMLElement>(".list-row[data-row-index]");

    const urlMap: Record<string, string> = {
      "0": "sumedida.com",
      "1": "summit2025.co",
      "2": "urbanosmedelin.com",
      "3": "app.sucrm.co",
      "4": "panel.suapp.co",
      "5": "auditoria.j24:15.com",
    };

    const openIndices = new Set<number>();
    let countdownInterval: ReturnType<typeof setInterval> | null = null;

    function restartAnimations(el: HTMLElement) {
      const animated = el.querySelectorAll<HTMLElement>('[class*="anim-"]');
      const ring = el.querySelector<SVGCircleElement>(".score-ring");
      animated.forEach((a) => { a.style.animationName = "none"; });
      if (ring) ring.style.animationName = "none";
      void el.offsetHeight;
      animated.forEach((a) => { a.style.animationName = ""; });
      if (ring) ring.style.animationName = "";
    }

    function triggerJsAnimations(el: HTMLElement) {
      el.querySelectorAll<HTMLElement>(".anim-countup[data-target]").forEach((countEl) => {
        const goal = parseInt(countEl.dataset.target ?? "0", 10);
        countEl.textContent = "0";
        let current = 0;
        const step = Math.ceil(goal / 40);
        const timer = setInterval(() => {
          current = Math.min(current + step, goal);
          countEl.textContent = current.toLocaleString("es-CO");
          if (current >= goal) clearInterval(timer);
        }, 30);
      });

      const scoreNum = el.querySelector<HTMLElement>(".score-num");
      if (scoreNum) {
        scoreNum.textContent = "0";
        let n = 0;
        const t = setInterval(() => {
          n = Math.min(n + 3, 94);
          scoreNum.textContent = String(n);
          if (n >= 94) clearInterval(t);
        }, 20);
      }

      if (countdownInterval) clearInterval(countdownInterval);
      const nums = el.querySelectorAll<HTMLElement>(".countdown-num");
      if (nums.length) {
        const values = Array.from(nums).map((n) => parseInt(n.textContent ?? "0", 10));
        countdownInterval = setInterval(() => {
          values[values.length - 1]--;
          if (values[values.length - 1] < 0) {
            values[values.length - 1] = 59;
            if (values.length > 1) values[values.length - 2]--;
          }
          nums.forEach((n, i) => { n.textContent = String(values[i]).padStart(2, "0"); });
        }, 1000);
      }
    }

    // ── Unified expand: works for desktop and mobile ──────────────────────────
    function expandRow(index: number) {
      if (openIndices.has(index)) return;
      openIndices.add(index);

      const row = root.querySelector<HTMLElement>(`.list-row[data-row-index="${index}"]`);
      if (!row) return;

      const preview = row.querySelector<HTMLElement>(".inline-preview");
      const content = row.querySelector<HTMLElement>(".mockup-mobile-content");
      if (!preview || !content) return;

      row.classList.add("expanded");

      const pool = root.querySelector<HTMLElement>(`.mockup[data-mockup="${index}"]`);
      if (pool) {
        const clone = pool.cloneNode(true) as HTMLElement;
        clone.style.display = "block";
        content.innerHTML = "";
        content.appendChild(clone);
        restartAnimations(clone);
        triggerJsAnimations(clone);
      }

      const urlEl = row.querySelector<HTMLElement>(".url-text-mobile");
      if (urlEl) urlEl.textContent = urlMap[String(index)] ?? "j24:15.com";

      preview.style.maxHeight = "300px";
    }

    function collapseAll() {
      openIndices.clear();
      rows.forEach((r) => {
        r.classList.remove("expanded");
        const p = r.querySelector<HTMLElement>(".inline-preview");
        if (p) p.style.maxHeight = "0";
      });
      if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
    }

    // ── Scroll-driven (all devices) ───────────────────────────────────────────
    let rafPending = false;

    function updateFromScroll() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        rafPending = false;
        const vh = window.innerHeight;
        const rect = root.getBoundingClientRect();

        if (rect.top > vh * 0.8) {
          collapseAll();
          return;
        }

        const readingLine = vh * 0.45;
        let closest: HTMLElement | null = null;
        let closestDist = Infinity;

        rows.forEach((row) => {
          const r = row.getBoundingClientRect();
          const mid = (r.top + r.bottom) / 2;
          const dist = Math.abs(mid - readingLine);
          if (dist < closestDist) { closestDist = dist; closest = row; }
        });

        if (closest) {
          expandRow(parseInt((closest as HTMLElement).dataset.rowIndex ?? "0", 10));
        }
      });
    }

    window.addEventListener("scroll", updateFromScroll, { passive: true });
    updateFromScroll();


    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("scroll", updateFromScroll);
      if (countdownInterval) clearInterval(countdownInterval);
    }, { once: true });
  }

  document.addEventListener("astro:page-load", initWhatWeDo);
</script>
