---
import Store from "../../assets/icons/Store.astro";
import Rocket2 from "../../assets/icons/Rocket2.astro";
import Design from "../../assets/icons/Design.astro";
import Develop from "../../assets/icons/Develop.astro";
import Validation from "../../assets/icons/Validation.astro";

const items = [
  {
    title: "Páginas web para negocios",
    content: "Sitios diseñados para comunicar con claridad, generar confianza y facilitar el contacto con clientes potenciales.",
    icon: "store",
  },
  {
    title: "Páginas web para eventos",
    content: "Espacios digitales para informar, registrar asistentes y centralizar toda la comunicación del evento.",
    icon: "rocket",
  },
  {
    title: "Proyectos inmobiliarios",
    content: "Páginas enfocadas en captar interés real y organizar la información de posibles compradores.",
    icon: "design",
  },
  {
    title: "Automatización de procesos",
    content: "Flujos que conectan formularios, mensajes y herramientas para reducir tareas manuales y mejorar el seguimiento.",
    icon: "develop",
  },
  {
    title: "Desarrollos a medida",
    content: "Soluciones personalizadas según necesidades específicas que no encajan en un formato estándar.",
    icon: "custom",
  },
  {
    title: "Optimización y soporte",
    content: "Ajustes, mejoras y mantenimiento para que todo siga funcionando correctamente en el tiempo.",
    icon: "support",
  },
];

const numColor = ["text-tertiary", "text-secondary"];
---

<!-- Numbered list -->
<div class="w-full flex flex-col border-t border-white/10" data-list-col>
  {
    items.map((item, i) => (
      <div
        data-reveal
        data-reveal-delay={String(i * 50)}
        class="list-row flex flex-col border-b border-white/10"
        data-row-index={i}
      >
        <!-- Main row content -->
        <div class="flex flex-row items-start gap-5 py-7">
          <span class={`text-4xl sm:text-5xl font-bold tabular-nums leading-none shrink-0 mt-0.5 ${numColor[i % 2]}`}>
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="flex flex-col gap-1.5 grow">
            <h3 class="text-sm sm:text-base font-bold uppercase tracking-wide text-white">
              {item.title}
            </h3>
            <p class="text-sm font-light text-white/60 leading-relaxed">
              {item.content}
            </p>
          </div>
          <div class="flex items-center gap-2 shrink-0 mt-0.5">
            <div class="w-6 h-6 opacity-20">
              {item.icon === "store" && <Store color="#FFF" />}
              {item.icon === "rocket" && <Rocket2 color="#FFF" />}
              {item.icon === "design" && <Design color="#FFF" />}
              {item.icon === "develop" && <Develop color="#FFF" />}
              {item.icon === "custom" && <Develop color="#FFF" />}
              {item.icon === "support" && <Validation color="#FFF" />}
            </div>
          </div>
        </div>

        <!-- Mobile inline preview -->
        <div class="inline-preview overflow-hidden" style="max-height:0;transition:max-height 0.45s cubic-bezier(0.23,1,0.32,1);">
          <div class="pb-4 px-3">
            <div class="browser-frame rounded-xl overflow-hidden border border-white/10 bg-[#1a1a1a] shadow-2xl">
              <!-- Chrome bar — matches desktop -->
              <div class="flex items-center gap-2 px-3 py-2 bg-[#2a2a2a] border-b border-white/10">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
                </div>
                <div class="flex-1 mx-2 bg-[#3a3a3a] rounded-md px-2.5 py-0.5 flex items-center gap-1.5">
                  <svg class="w-2.5 h-2.5 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0-1.1.9-2 2-2s2 .9 2 2-.9 2-2 2-2-.9-2-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10-4.5 10-10 10z"/></svg>
                  <span class="url-text-mobile text-[9px] text-white/30 font-mono truncate">j24:15.com</span>
                </div>
              </div>
              <!-- Mockup viewport — same structure as desktop, content vertically centered -->
              <div class="mockup-mobile-content relative overflow-hidden bg-white flex items-center justify-center" style="height:220px;"></div>
            </div>
          </div>
        </div>
      </div>
    ))
  }
</div>
