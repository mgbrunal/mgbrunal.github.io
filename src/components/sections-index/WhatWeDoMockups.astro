<style is:global>
  /* ── Mockup visibility ── */
  .mockup {
    position: absolute;
    inset: 0;
    display: none;
  }
  .mockup.active {
    display: block;
  }

  /* ── Common skeleton pieces ── */
  .sk-line {
    height: 8px;
    background: #e5e5e5;
    border-radius: 4px;
    margin-top: 6px;
  }
  .mockup-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid #f0f0f0;
    background: white;
  }

  /* ── Keyframes ── */
  @keyframes fadein {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideup {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes barup {
    from { transform: scaleY(0); }
    to   { transform: scaleY(1); }
  }
  @keyframes flowin {
    0%   { opacity: 0; transform: translateX(-8px); }
    100% { opacity: 1; transform: translateX(0); }
  }
  @keyframes auditrow {
    0%   { opacity: 0; transform: translateX(-6px); }
    100% { opacity: 1; transform: translateX(0); }
  }
  @keyframes tagpop {
    0%   { opacity: 0; transform: scale(0.8); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes scorering {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 6; }
  }

  /* ── Animation classes ── */
  .anim-fadein  { animation: fadein   0.4s cubic-bezier(0.23,1,0.32,1) both; animation-iteration-count: 1; }
  .anim-slideup { animation: slideup  0.5s cubic-bezier(0.23,1,0.32,1) both; }
  .anim-flow    { animation: flowin   0.4s cubic-bezier(0.23,1,0.32,1) both; }
  .anim-auditrow{ animation: auditrow 0.35s cubic-bezier(0.23,1,0.32,1) both; }
  .anim-bar     { animation: barup    0.5s cubic-bezier(0.23,1,0.32,1) both; transform-origin: bottom; }
  .anim-tag     { animation: tagpop   0.3s cubic-bezier(0.23,1,0.32,1) both; }

  /* ── Countdown ── */
  .countdown-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 6px 10px;
    min-width: 38px;
  }
  .countdown-num {
    color: #C5FF3C;
    font-size: 14px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .countdown-label {
    color: rgba(255,255,255,0.4);
    font-size: 7px;
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Flow nodes ── */
  .flow-node {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 5px 10px;
    width: 100%;
  }
  .flow-node span { color: rgba(255,255,255,0.8); font-size: 8px; font-weight: 500; }
  .flow-arrow { color: rgba(255,255,255,0.2); font-size: 10px; line-height: 1; text-align: center; }

  /* ── Dashboard ── */
  .dash-stat {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    padding: 8px;
  }
  .dash-stat-val   { color: white; font-size: 16px; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1; }
  .dash-stat-label { color: rgba(255,255,255,0.35); font-size: 7px; margin-top: 2px; }
  .bar {
    flex: 1;
    height: var(--h, 50%);
    background: rgba(255,255,255,0.15);
    border-radius: 3px 3px 0 0;
    transform-origin: bottom;
  }

  /* ── Audit ── */
  .audit-row { display: flex; align-items: center; gap: 5px; padding: 4px 0; border-bottom: 1px solid #f0f0f0; }
  .audit-label { flex: 1; font-size: 8px; color: #333; }
  .audit-score { font-size: 9px; font-weight: 700; }
  .score-ring  { animation: scorering 1s cubic-bezier(0.23,1,0.32,1) 0.3s both; }

  /* ── Countdown light ── */
  .cntdwn-l {
    display: flex; flex-direction: column; align-items: center;
    background: white; border: 1px solid #e8e8e8; border-radius: 6px;
    padding: 6px 10px; min-width: 38px;
  }
  .cntdwn-num-l { color: #060A06; font-size: 14px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }
  .cntdwn-lbl-l { color: #aaa; font-size: 6.5px; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.05em; }

  /* ── Housing project light ── */
  .proj-spec-l {
    background: #f5f5f5; border: 1px solid #e8e8e8; border-radius: 5px;
    padding: 4px 8px; display: flex; flex-direction: column; align-items: center; gap: 1px;
  }
