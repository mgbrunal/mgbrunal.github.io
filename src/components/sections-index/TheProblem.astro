---
import Cross from "../../assets/icons/Cross.astro";
import Warning from "../../assets/icons/Warning.astro";

const items = [
  "Información que no fluye entre sistemas",
  "Procesos manuales que consumen tiempo",
  "Herramientas que no están integradas",
  "Experiencias que no guían al usuario correctamente",
  "Seguimiento inconsistente de oportunidades",
];
---

<div class="w-full h-full flex flex-col items-center justify-center py-20">
  <div class="w-full xl:max-w-[75%] px-10 sm:px-20">
    <div class="w-full h-full flex flex-col items-start justify-center gap-8">
      <div
        class="w-full flex flex-col items-center justify-center gap-4 text-center"
      >
        <p
          class="text-sm sm:text-base font-light text-black uppercase"
          data-reveal
        >
          El problema
        </p>

        <div data-reveal data-reveal-delay="80" class="w-full bg-white px-5 py-4">
          <h1 class="text-3xl sm:text-5xl font-bold text-black drop-shadow">
            Cuando la tecnología no está bien estructurada...
          </h1>
        </div>

        <p data-reveal data-reveal-delay="160" class="text-sm sm:text-lg font-semibold text-black drop-shadow">
          Muchos negocios tienen herramientas, procesos y presencia digital, pero algo falla en la forma en que todo está conectado.
        </p>
      </div>
    </div>
  </div>

  <div class="w-full">
    <div class="w-full flex flex-col items-center justify-start gap-4">
      <div data-reveal-fade data-reveal-delay="200" class="w-full py-20 overflow-hidden">
        <div class="flex w-max whitespace-nowrap animate-text-slider">
          {
            items.map((text, i) => (
              <div class="flex flex-row gap-2 w-full bg-black shadow-lg shadow-secondary mx-12 px-5 py-4">
                {i % 2 === 0 ? (
                  <Cross color="#F00" />
                ) : (
                  <Warning color="#FF0" />
                )}
                <span class="text-lg font-medium text-white">{text}</span>
              </div>
            ))
          }
          {
            items.map((text, i) => (
              <div class="flex flex-row gap-2 w-full bg-black shadow-lg shadow-secondary mx-12 px-5 py-4">
                {i % 2 === 0 ? (
                  <Cross color="#F00" />
                ) : (
                  <Warning color="#FF0" />
                )}
                <span class="text-lg font-medium text-white">{text}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="w-full xl:max-w-[75%] px-10 sm:px-20">
    <div class="w-full flex flex-col items-center justify-start gap-4">
      <p
        data-reveal
        class="text-sm sm:text-lg text-center font-bold bg-secondary/50 text-black rounded-full p-2"
      >
        El problema no es la falta de herramientas, sino cómo están organizadas.
      </p>
    </div>
  </div>
</div>

<style>
  @media (hover: hover) and (pointer: fine) {
    .animate-text-slider:hover {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-text-slider {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      white-space: normal;
    }
  }
</style>
