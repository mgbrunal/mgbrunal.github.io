---
import ArrowUpRight from "../../assets/icons/ArrowUpRight.astro";
---

<div class="relative w-full h-full flex flex-col items-center justify-center">
  <div class="w-full h-full xl:max-w-[75%] px-10 sm:px-20">
    <!-- Video background -->
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    >
      <source src="/videos/hero.webm" type="video/webm" />
    </video>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/80"></div>

    <!-- Content -->
    <div
      class="relative z-10 w-full h-full flex flex-col items-center justify-center gap-12"
    >
      <h1 class="text-4xl sm:text-6xl font-bold text-white drop-shadow-lg">
        Desarrollo web enfocado en resultados reales
      </h1>

      <div class="w-full flex flex-col items-start justify-center gap-4">
        <p class="text-sm sm:text-lg font-semibold text-white">
          Creamos páginas web, automatizaciones y soluciones digitales que
          ayudan a negocios a captar oportunidades y operar de forma más
          eficiente.
        </p>
        <div
          class="flex flex-col sm:flex-row items-start justify-start gap-4 w-full"
        >
          <button
            class="flex flex-row items-center gap-2 bg-secondary hover:bg-secondary/60 transition-all duration-500 text-black border-2 border-black font-semibold uppercase px-5 py-4"
            >Ver servicios<div class="w-6 h-6">
              <ArrowUpRight color="#000" />
            </div></button
          >
          <button
            class="flex flex-row items-center gap-2 bg-tertiary hover:bg-tertiary/60 transition-all duration-500 text-black border-2 border-black font-semibold uppercase px-5 py-4"
            >Agendar asesoría gratuita<div class="w-6 h-6">
              <ArrowUpRight color="#000" />
            </div>
          </button>
        </div>
        <p class="text-xs sm:text-sm text-white drop-shadow">
          Soluciones prácticas, sin complejidad innecesaria
        </p>
      </div>
    </div>
  </div>
</div>
