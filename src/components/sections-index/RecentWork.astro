---
const projects = [
  { file: "223collectionhotels.webp", url: "223collectionhotels.com", label: "223 Collection Hotels" },
  { file: "celerik.webp",             url: "celerik.com",             label: "Celerik" },
  { file: "datalabusa.webp",          url: "datalabusa.webflow.io",   label: "DataLab USA" },
  { file: "josue2415.webp",           url: "josue2415.com",           label: "Josue 24:15" },
  { file: "mediserips.webp",          url: "mediserips.com",          label: "Mediserips" },
  { file: "skimmer.webp",             url: "getskimmer.com",          label: "Skimmer" },
];
---

<div class="w-full flex flex-col items-center justify-center py-20 overflow-hidden gap-12">
  <div class="w-full xl:max-w-[75%] px-10 sm:px-20 flex flex-col items-start gap-4">
    <p data-reveal class="text-sm sm:text-base font-light text-white uppercase">Trabajo reciente</p>
    <h2 data-reveal data-reveal-delay="80" class="text-3xl sm:text-5xl font-bold text-white drop-shadow-lg">
      Proyectos que hablan por sí solos
    </h2>
  </div>

  <!-- Marquee track -->
  <div
    class="marquee-outer w-full relative"
    style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
           -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);"
  >
    <div class="marquee-track flex gap-6 w-max">
      {[...projects, ...projects].map((p) => (
        <a
          href={`https://${p.url}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Visitar ${p.label}`}
          class="browser-card group shrink-0 w-[320px] sm:w-[400px] rounded-xl overflow-hidden border border-white/10 bg-[#1a1a1a] shadow-2xl no-underline"
        >
          <!-- Chrome bar -->
          <div class="flex items-center gap-2 px-3 py-2 bg-[#2a2a2a] border-b border-white/10">
            <div class="flex gap-1.5 shrink-0">
              <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
            </div>
            <div class="flex-1 flex items-center gap-1.5 bg-[#1a1a1a] rounded px-2 py-0.5 min-w-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-white/30 shrink-0">
                <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 00-5.25 5.25v3a3 3 0 00-3 3v6.75a3 3 0 003 3h10.5a3 3 0 003-3v-6.75a3 3 0 00-3-3v-3c0-2.9-2.35-5.25-5.25-5.25zm3.75 8.25v-3a3.75 3.75 0 10-7.5 0v3h7.5z" clip-rule="evenodd" />
              </svg>
              <span class="text-[10px] text-white/40 truncate font-light">{p.url}</span>
            </div>
            <!-- Visit indicator -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-3.5 h-3.5 text-white/0 group-hover:text-white/50 shrink-0 transition-colors duration-200"
            >
              <path d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
          <!-- Screenshot -->
          <div class="relative overflow-hidden" style="height: 220px;">
            <img
              src={`/screenshots/${p.file}`}
              alt={p.label}
              class="w-full h-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
              loading="lazy"
              decoding="async"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 32s linear infinite;
  }

  .marquee-outer:hover .marquee-track {
    animation-play-state: paused;
  }

  .browser-card {
    transition: transform 220ms cubic-bezier(0.23, 1, 0.32, 1),
                box-shadow 220ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .browser-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 24px 48px -8px rgba(0, 0, 0, 0.6);
  }

  .browser-card:active {
    transform: translateY(0) scale(0.98);
    transition-duration: 120ms;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
    .browser-card {
      transition: none;
    }
    .browser-card img {
      transition: none;
    }
  }
</style>
