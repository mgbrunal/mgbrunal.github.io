---
import ArrowUpRight from "../assets/icons/ArrowUpRight.astro";

const { variant = "index" } = Astro.props;
---

<div class="relative w-full min-h-[100dvh] flex flex-col items-center justify-center">
  <div class="w-full h-full xl:max-w-[75%] px-5 sm:px-20">
    <!-- Video background -->
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    >
      <source src="/videos/finalcta.webm" type="video/webm" />
    </video>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/80"></div>

    <!-- Content -->
    <div
      class="relative z-10 w-full h-full flex flex-col items-center justify-center gap-12"
    >
      <h1 data-reveal class="text-4xl sm:text-6xl font-bold text-white drop-shadow-lg">
        Cuéntanos qué necesitas y lo aterrizamos contigo
      </h1>

      <div class="w-full flex flex-col items-start justify-center gap-4">
        <p data-reveal data-reveal-delay="100" class="text-sm sm:text-lg font-semibold text-white">
          Si tienes una idea, un proyecto en marcha o simplemente quieres
          mejorar lo que ya tienes, podemos ayudarte a definir la mejor solución
          sin complicaciones.
        </p>

        <div
          data-reveal
          data-reveal-delay="200"
          class="flex flex-col sm:flex-row items-start justify-start gap-4 w-full"
        >
          {
            variant === "index" && (
              <a
                href="/info"
                class="flex flex-row items-center gap-2 bg-secondary text-black border-2 border-black font-semibold uppercase px-5 py-4 transition-[background-color,transform] duration-200 ease-out-strong can-hover:hover:bg-secondary/60 active:scale-[0.97]"
              >
                Quienes somos?
                <div class="w-6 h-6">
                  <ArrowUpRight color="#000" />
                </div>
              </a>
            )
          }
          <a
            href="/contacto"
            class="flex flex-row items-center gap-2 bg-tertiary text-black border-2 border-black font-semibold uppercase px-5 py-4 transition-[background-color,transform] duration-200 ease-out-strong can-hover:hover:bg-tertiary/60 active:scale-[0.97]"
            >Agendar asesoría gratuita<div class="w-6 h-6">
              <ArrowUpRight color="#000" />
            </div>
          </a>
        </div>

        <div
          data-reveal
          data-reveal-delay="300"
          class="flex flex-col sm:flex-row items-start justify-start gap-4 w-full"
        >
          <p
            class="text-xs sm:text-sm text-white font-light drop-shadow p-2 bg-primary rounded-full"
          >
            Sin compromiso
          </p>
          <p
            class="text-xs sm:text-sm text-white font-light drop-shadow p-2 bg-primary rounded-full"
          >
            Respuesta rápida
          </p>
          <p
            class="text-xs sm:text-sm text-white font-light drop-shadow p-2 bg-primary rounded-full"
          >
            Te orientamos desde el primer contacto
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
