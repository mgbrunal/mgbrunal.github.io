---

<div class="relative w-full h-[20vh] flex flex-col items-center justify-center">
  <div class="w-full h-full px-10 sm:px-20">
    <!-- Video background -->
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    >
      <source src="/videos/hero.webm" type="video/webm" />
    </video>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/80"></div>

    <!-- Content -->
    <div
      class="relative z-10 w-full h-full flex flex-row items-center justify-start gap-4"
    >
      <a href="/">
        <div class="bg-black h-20 w-20 rounded-full"></div>
      </a>
      <div class="w-full flex flex-col items-start justify-start gap-2">
        <h1 class="text-lg sm:text-xl font-bold text-white drop-shadow-lg">
          JOSUE 24:15 SAS
        </h1>

        <h5 class="text-xs sm:text-sm font-light text-white">
          Desarrollo de software enfocado en resultados reales
        </h5>
      </div>
    </div>
  </div>
</div>
