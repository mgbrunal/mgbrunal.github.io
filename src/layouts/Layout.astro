---
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import Nav from "../components/Nav.astro";

interface Props {
  title: string;
  lang: "es" | "en";
}

const { title, lang = "es" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#000" />
    <SEO
      title={`${title} - JOSUE 24:15`}
      description="Welcome to the professional portfolio of Mauricio Garzon. As a Software Engineer, I bring expertise in web and mobile software development. With a commitment to excellence and a passion for Javascript development, focused on delivering results. Navigate through my career journey, discover my skills, and learn how I can contribute to your projects."
      canonical="https://mgbrunal.github.io"
      openGraph={{
        basic: {
          title: `${title} - JOSUE 24:15`,
          type: "website",
          image:
            "https://media.licdn.com/dms/image/C4D03AQETLSMaC7f-WQ/profile-displayphoto-shrink_800_800/0/1649435378295?e=1712188800&v=beta&t=pYFUEe1cTBJ7ybLHxPdX5X29FVL79nZ0uuZaTCIm5co",
        },
      }}
    />
    <ClientRouter />
  </head>
  <body>
    <div class="min-h-screen max-w-screen bg-black overscroll-none">
      <Nav />
      <slot />
    </div>
  </body>
</html>

<style is:global>
  /* Scroll reveal */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 500ms cubic-bezier(0.23, 1, 0.32, 1),
      transform 500ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  [data-reveal-fade] {
    opacity: 0;
    transition: opacity 600ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  [data-reveal].is-visible,
  [data-reveal-fade].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-fade] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  function initReveal() {
    const elements = document.querySelectorAll<HTMLElement>(
      "[data-reveal], [data-reveal-fade]"
    );
    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.revealDelay ?? "0", 10);
          if (delay) {
            setTimeout(() => el.classList.add("is-visible"), delay);
          } else {
            el.classList.add("is-visible");
          }
          observer.unobserve(el);
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );

    elements.forEach((el) => observer.observe(el));
  }

  document.addEventListener("astro:page-load", initReveal);
</script>
