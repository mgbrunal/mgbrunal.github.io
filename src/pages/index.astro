---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections-index/Hero.astro";
import WhatWeDo from "../components/sections-index/WhatWeDo.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Inicio" lang="es">
  <main>
    <section id="hero" class="h-[100vh] overflow-hidden bg-black">
      <Hero />
    </section>
    <section id="what_we_do" class="min-h-[100vh] bg-secondary/40">
      <WhatWeDo />
    </section>
    <section id="final_cta" class="h-[100vh] overflow-hidden bg-black">
      <FinalCTA />
    </section>

    <Footer />
  </main>
</Layout>
