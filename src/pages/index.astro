---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections-index/Hero.astro";
import HowWeWork from "../components/sections-index/HowWeWork.astro";
import FinalCTA from "../components/sections-index/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Inicio" lang="es">
  <main>
    <section id="hero" class="h-[100vh] overflow-hidden bg-black">
      <Hero />
    </section>
    <section id="how_we_work" class="min-h-[100vh] bg-white">
      <HowWeWork />
    </section>
    <section id="final_cta" class="h-[100vh] overflow-hidden bg-black">
      <FinalCTA />
    </section>

    <Footer />
  </main>
</Layout>
