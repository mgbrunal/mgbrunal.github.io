---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections-index/Hero.astro";
import WhatWeDo from "../components/sections-index/WhatWeDo.astro";
import TheProblem from "../components/sections-index/TheProblem.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Inicio" lang="es">
  <main>
    <section id="hero" class="h-[90svh] overflow-hidden bg-black">
      <Hero />
    </section>
    <section id="what_we_do" class="min-h-[100dvh] bg-surface">
      <WhatWeDo />
    </section>
    <section id="the_problem" class="h-[90svh] overflow-hidden bg-tertiary">
      <TheProblem />
    </section>
    <section id="final_cta" class="h-[100dvh] overflow-hidden bg-black">
      <FinalCTA />
    </section>

    <Footer />
  </main>
</Layout>
