---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contacto"
  lang="es"
  description="¿Tienes un proyecto en mente? Escríbenos y cuéntanos qué necesitas. Respondemos en menos de 24 horas. JOSUE 24:15 SAS — Casa de Software."
>
  <main>
    <section id="header" class="h-[20svh] bg-black">
      <Header />
    </section>
    <section id="contact" class="min-h-[90svh] bg-white">
      <Contact />
    </section>

    <Footer />
  </main>
</Layout>
