---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import WhoWeAre from "../components/sections-about-us/WhoWeAre.astro";
import HowWeWork from "../components/sections-about-us/HowWeWork.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Quiénes Somos"
  lang="es"
  description="Somos Mauricio Garzón y Laura Mestra, un equipo de dos desarrolladores senior con más de 6 años de experiencia construyendo software de alto impacto para negocios en Colombia."
>
  <main>
    <section id="header" class="h-[20svh] overflow-hidden bg-black">
      <Header />
    </section>
    <section id="who_we_are" class="min-h-[90svh] bg-surface">
      <WhoWeAre />
    </section>
    <section id="how_it_works" class="min-h-[100dvh] bg-white">
      <HowWeWork />
    </section>
    <section id="final_cta" class="h-[100dvh] overflow-hidden bg-black">
      <FinalCTA variant="info" />
    </section>

    <Footer />
  </main>
</Layout>
